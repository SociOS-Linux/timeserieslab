{
  "schemaVersion": "functional-service.v1",
  "service": {
    "id": "timeserieslab.holmes.timeseries-pilot",
    "name": "TimeSeriesLab Holmes TimeSeries Pilot",
    "ownerRepository": "SociOS-Linux/timeserieslab",
    "status": "experimental",
    "description": "Offline deterministic timeseries functional surface emitted by timeserieslab for governed promotion."
  },
  "function": "timeseries",
  "model": {
    "modelRef": "urn:socioprophet:functional-model:timeserieslab:deterministic-timeseries:v0",
    "adapterRefs": [],
    "runtime": "python-stdlib-offline-smoke",
    "mutableStatePolicy": "forbidden-in-sourceos"
  },
  "inputs": [
    "series/query",
    "series/corpus"
  ],
  "outputs": [
    "timeseries/features",
    "ranking/candidates",
    "evidence/smoke-receipt"
  ],
  "evals": {
    "required": true,
    "references": [
      "examples/smoke-input.json",
      "examples/smoke-output.json",
      "evidence/smoke-receipt.example.json"
    ],
    "minimumPromotionGate": "candidate requires signed eval and dataset provenance"
  },
  "governance": {
    "ledgerRequired": true,
    "guardrailRequired": true,
    "routingRequired": true,
    "policyRefs": [
      "SocioProphet/model-governance-ledger",
      "SocioProphet/guardrail-fabric",
      "SocioProphet/model-router",
      "SocioProphet/holmes"
    ]
  },
  "sourceosCarry": {
    "allowed": true,
    "carriesMutableModelState": false,
    "clientRefRequired": true,
    "launchProfileRefs": [
      "urn:srcos:model-carry:functional-service:timeserieslab-holmes-pilot"
    ]
  }
}
